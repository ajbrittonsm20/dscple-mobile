{
  "expo": {
    "name": "DSCPLE",
    "slug": "dscple",
    "scheme": "dscple",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EFEFEF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dscple.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#EFEFEF"
      },
      "package": "com.dscple.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/waves-icon.png",
          "color": "#8B6037"
        }
      ]
    ]
  }
}
